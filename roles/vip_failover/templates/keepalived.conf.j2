vrrp_instance VI_1 {
    state {{ 'MASTER' if inventory_hostname == vip_master_host else 'BACKUP' }}
    interface {{ vip_interface }}
    virtual_router_id 51
    priority {{ vip_priority_master if inventory_hostname == vip_master_host else vip_priority_backup }}
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass {{ vip_auth_pass }}
    }
    virtual_ipaddress {
        {{ vip_address }}/{{ vip_netmask }}
    }
}

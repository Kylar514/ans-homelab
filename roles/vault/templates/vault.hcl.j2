# Managed by Ansible — do not edit manually

storage "raft" {
path    = "/opt/vault/data"
node_id = "{{ inventory_hostname }}"
}

listener "tcp" {
address     = "0.0.0.0:8200"
tls_disable = true
}

api_addr      = "http://{{ ansible_host }}:8200"
cluster_addr  = "https://{{ ansible_host }}:8201"
ui            = true
disable_mlock = true
